<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- La Carte osmdroid -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Barre de recherche flottante (Glassmorphism) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#D9FFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/search_view"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:iconifiedByDefault="false"
            app:queryBackground="@android:color/transparent"
            app:queryHint="Rechercher un lieu..."
            app:searchIcon="@android:drawable/ic_menu_search" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Bouton Ma Position avec Gradient -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"
        android:contentDescription="Ma position"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="@null"
        app:backgroundResource="@drawable/gradient_primary"
        app:tint="@color/white" />

    <!-- Inclusion de la BottomSheet Place Preview -->
    <include layout="@layout/bottom_sheet_place_preview" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>