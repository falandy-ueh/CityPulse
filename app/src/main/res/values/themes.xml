<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CityPulse" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Palette de couleurs M3 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="colorSecondaryContainer">@color/secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/onSecondaryContainer</item>

        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/onTertiary</item>
        <item name="colorTertiaryContainer">@color/tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/onTertiaryContainer</item>

        <item name="android:windowBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/onSurface_light</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant_light</item>
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant_light</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.CityPulse.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CityPulse.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.CityPulse.Large</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.CityPulse.HeadlineLarge</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.CityPulse.TitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.CityPulse.BodyLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.CityPulse.LabelMedium</item>
    </style>

    <style name="Theme.CityPulse" parent="Base.Theme.CityPulse" />

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.CityPulse</item>
    </style>

    <!-- Navigation Styles -->
    <style name="Widget.CityPulse.ActiveIndicator" parent="Widget.Material3.NavigationBar.ActiveIndicator">
        <item name="android:color">@color/primaryContainer</item>
    </style>

    <!-- Glassmorphism Styles -->
    <style name="Widget.CityPulse.Card.Glass" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/glass_white</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>